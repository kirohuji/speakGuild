generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

model User {
  id                  String    @id
  name                String
  email               String
  emailVerified       Boolean   @default(false)
  image               String?
  username            String?   @unique
  phoneNumber         String?   @unique
  phoneNumberVerified Boolean   @default(false)
  role                UserRole  @default(user)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions            Session[]
  accounts            Account[]
  vocabularyWords     VocabularyWord[]
  dailyActivities     DailyActivity[]
  userPreference      UserPreference?
  fileReferences      FileReference[]
  notificationReads   NotificationRead[]
  notificationTargets NotificationTarget[]
  sentNotifications   Notification[]
  orders              Order[]
  membership          UserMembership?
  referralCode        ReferralCode?
  referredBy          Referral?
  achievements        UserAchievement[]
  feedbacks           Feedback[]

  // --- English Output Training: 用户画像扩展 ---
  learningGoals        String[]               @default([])
  outputLevel          String                 @default("L1")
  outputLevelDetail    Json?
  totalXp              Int                    @default(0)
  points               Int                    @default(0)
  userLevel            Int                    @default(1)
  sceneProgresses      UserSceneProgress[]
  chunkProgresses      UserChunkProgress[]
  expressionItems      ExpressionItem[]
  scriptRecords        ScriptRecord[]
  scriptDialogues      ScriptDialogue[]
  practiceSessions     PracticeSession[]
  explorationRecords   ExplorationRecord[]
  onboardingStatus     OnboardingStatus?
  userAchievementsV2   UserAchievementV2[]
  gameSaves            GameSave[]
  checkIns             UserCheckIn[]
  pointTransactions    PointTransaction[]
  aiUsages             AiUsageDaily[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model VocabularyWord {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  term             String
  definition       String?
  createdAt        DateTime @default(now())
  @@unique([userId, term])
  @@index([userId, createdAt(sort: Desc)])
  @@map("vocabulary_word")
}

// ---- 用户看板域 ----

model DailyActivity {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  date     DateTime @db.Date
  count    Int      @default(1)
  @@unique([userId, date])
  @@map("daily_activity")
}

model UserPreference {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String       @unique
  autoPlay       Boolean      @default(false)
  language       String       @default("zh-CN")
  theme          String       @default("system")
  themePresetId  String?
  themePreset    ThemePreset? @relation(fields: [themePresetId], references: [id], onDelete: SetNull)
  updatedAt      DateTime     @updatedAt
  @@map("user_preference")
}

// ── 沉浸式主题套装 ──
model ThemePreset {
  id          String   @id @default(cuid())
  name        String                           // 主题名称
  description String?                          // 描述
  sortOrder   Int      @default(0)            // 排序
  isActive    Boolean  @default(true)         // 是否启用
  isDefault   Boolean  @default(false)        // 是否默认主题

  // 背景类型: gradient | image | video
  bgType      String   @default("gradient")

  // ── Light 模式色板（JSON: { background, foreground, primary, card, muted, accent, border ... }）──
  lightColors       Json?
  // ── Light 模式背景（CSS gradient string 或图片 URL）──
  lightBackground   String?  @db.Text
  // ── Light 模式装饰配置（JSON: [{ type, color, position, size, blur, animation }]）──
  lightDecorations  Json?

  // ── Dark 模式（同上）──
  darkColors        Json?
  darkBackground    String?  @db.Text
  darkDecorations   Json?

  // ── 音效 ──
  bgmUrl            String?  // 背景音效 URL（COS 上）
  bgmVolume         Float    @default(0.3)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userPreferences UserPreference[]

  @@map("theme_preset")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @default("")
  group       String   @default("basic")
  label       String   @default("")
  type        String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt
  @@map("system_config")
}

/// 每日一句：按日期管理的每日句子（首页展示）
model DailySentence {
  id          String   @id @default(cuid())
  date        DateTime @unique         /// 句子所属日期（仅日期部分有效）
  quote       String                   /// 英文句子
  translation String                   /// 中文翻译
  author      String   @default("")    /// 出处/作者
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, sortOrder])
  @@map("daily_sentence")
}

enum MembershipLevel {
  free
  standard
  advanced
}

model MembershipPlan {
  id                       String           @id @default(cuid())
  name                     String
  level                    MembershipLevel  @default(standard)
  price                    Int              /// 月付价格（分）
  yearlyPrice              Int?             /// 年付价格（分）
  period                   String
  durationDays             Int              @default(30)
  features                 String[]
  revenueCatEntitlementId  String?          /// RevenueCat 权益 ID（跨端同步用）
  highlighted              Boolean          @default(false)
  sortOrder                Int              @default(0)
  orders                   Order[]
  memberships              UserMembership[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  @@map("membership_plan")
}

/// 支付订单
enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum PaymentMethod {
  alipay
  wechat
}

model Order {
  id            String        @id @default(cuid())
  orderNo       String        @unique /// 商户订单号
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  plan          MembershipPlan @relation(fields: [planId], references: [id])
  planId        String
  amount        Int           /// 实付金额（分）
  paymentMethod PaymentMethod
  status        OrderStatus   @default(pending)
  paymentRef    String?       /// 支付网关交易号
  billingCycle  String        @default("monthly") /// monthly | yearly
  paidAt        DateTime?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  membership    UserMembership?
  coupon        Coupon?         @relation(fields: [couponId], references: [id])
  couponId      String?

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("order")
}

/// 用户会员状态
enum MembershipStatus {
  active
  expired
  cancelled
}

model UserMembership {
  id            String           @id @default(cuid())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String           @unique
  plan          MembershipPlan   @relation(fields: [planId], references: [id])
  planId        String
  status        MembershipStatus @default(active)
  order         Order?           @relation(fields: [orderId], references: [id])
  orderId        String?          @unique
  rcCustomerId  String?          /// RevenueCat 用户 ID（跨端同步）
  startedAt     DateTime         @default(now())
  expiredAt     DateTime
  autoRenew     Boolean          @default(false)
  cancelledAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status, expiredAt])
  @@map("user_membership")
}

// ---- 文件资产域 ----

enum FileAssetGroup {
  avatar
  library
  tts
  notification
}

enum FileAssetStatus {
  active
  deleted
}

model FileAsset {
  id               String          @id @default(cuid())
  sha256           String          @unique
  bucket           String
  region           String
  cosKey           String          @unique
  group            FileAssetGroup
  size             Int
  mimeType         String
  filename         String
  status           FileAssetStatus @default(active)
  refCount         Int             @default(0)
  lastReferencedAt DateTime?
  createdAt        DateTime        @default(now())
  references       FileReference[]
  resourceNodes    ResourceNode[]
  @@index([group, status, createdAt(sort: Desc)])
  @@index([status, refCount, createdAt])
  @@map("file_asset")
}

model FileReference {
  id        String    @id @default(cuid())
  asset     FileAsset @relation(fields: [assetId], references: [id])
  assetId   String
  bizType   String
  bizId     String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime  @default(now())
  @@unique([assetId, bizType, bizId, userId])
  @@index([bizType, bizId, userId])
  @@map("file_reference")
}

// ---- 资料库域 ----

enum ResourceNodeType {
  folder
  video_url
  video
  audio
  pdf
  image
  document
  other
}

/// 资料库节点（统一管理文件夹和资源项的树形结构）
model ResourceNode {
  id        String           @id @default(cuid())
  parent    ResourceNode?    @relation("ResourceTree", fields: [parentId], references: [id])
  parentId  String?
  children  ResourceNode[]   @relation("ResourceTree")
  name      String
  type      ResourceNodeType
  region    String?          /// 地区标识（null = 通用资料，适用于所有地区）
  asset     FileAsset?       @relation(fields: [assetId], references: [id])
  assetId   String?          /// 关联 COS 文件（video/audio/pdf/image/document/other 类型）
  url       String?          /// 外部链接（video_url 类型使用）
  description String?        @db.Text
  mimeType  String?          /// 文件 MIME 类型（冗余，方便前端展示图标）
  fileSize  Int?             /// 文件大小（冗余，方便前端展示）
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([parentId, sortOrder])
  @@index([region])
  @@index([type])
  @@map("resource_node")
}

// ---- 消息通知域 ----

enum TtsProvider {
  minimax
  cartesia
}

// ---- 消息通知域 ----

enum NotificationType {
  broadcast
  targeted
}

model Notification {
  id        String              @id @default(cuid())
  title     String
  content   String              @db.Text /// Markdown 格式内容
  type      NotificationType
  sentBy    User                @relation(fields: [sentById], references: [id])
  sentById  String
  isSpecial Boolean            @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  reads     NotificationRead[]
  targets   NotificationTarget[]
  @@index([type, createdAt(sort: Desc)])
  @@map("notification")
}

model NotificationRead {
  id             String       @id @default(cuid())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  readAt         DateTime     @default(now())
  @@unique([notificationId, userId])
  @@index([userId, readAt(sort: Desc)])
  @@map("notification_read")
}

model NotificationTarget {
  id             String       @id @default(cuid())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_target")
}

// ──── 优惠券/促销域 ────

enum CouponType {
  percentage
  fixed
  free_trial
}

model Coupon {
  id          String      @id @default(cuid())
  code        String      @unique
  type        CouponType
  value       Float       /// 折扣值（百分比如20=20%，固定金额单位分，试用天数）
  minAmount   Float?      /// 最低消费金额（分）
  maxUses     Int?
  usedCount   Int         @default(0)
  validFrom   DateTime    @default(now())
  validUntil  DateTime?
  isActive    Boolean     @default(true)
  orders      Order[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("coupon")
}

// ──── 邀请域 ────

model ReferralCode {
  id           String     @id @default(cuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code         String     @unique
  totalInvited Int        @default(0)
  totalReward  Int        @default(0)
  createdAt    DateTime   @default(now())
  referrals    Referral[]

  @@map("referral_code")
}

model Referral {
  id             String       @id @default(cuid())
  referrerId     String
  referrer       ReferralCode @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String       @unique
  referredUser   User         @relation(fields: [referredUserId], references: [id], onDelete: Cascade)
  rewardedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([referrerId])
  @@map("referral")
}

// ──── 成就域 ────

model Achievement {
  id          String             @id @default(cuid())
  key         String             @unique
  name        String
  description String
  icon        String
  category    String
  condition   Json
  sortOrder   Int                @default(0)
  users       UserAchievement[]
  createdAt   DateTime           @default(now())

  @@map("achievement")
}

model UserAchievement {
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@id([userId, achievementId])
  @@index([userId])
  @@map("user_achievement")
}

// ──── 反馈域 ────

enum FeedbackStatus {
  pending
  resolved
  closed
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  content   String         @db.Text
  contact   String?
  status    FeedbackStatus @default(pending)
  adminNote String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("feedback")
}

// ════════════════════════════════════════════════════════════
// English Output Training — 新增模型
// ════════════════════════════════════════════════════════════

// ──── Chunk 掌握状态枚举 ────
enum ChunkMasteryStatus {
  not_learned
  activated
  can_read
  can_output
  mastered
}

// ──── 表达库条目类型 ────
enum ExpressionType {
  word
  chunk
  error_sentence
  upgraded
  scene_phrase
  custom
}

// ──── 成就 V2 枚举 ────
enum AchievementCategory {
  milestone
  streak
  challenge
  mastery
  hidden
  first_time
}

enum AchievementRarity {
  common
  rare
  epic
  legendary
}

enum UserAchievementStatus {
  locked
  unlocked
  seen
}

// ──── 场景系统 ────

model SceneCategory {
  id        String  @id @default(cuid())
  name      String
  icon      String?
  sortOrder Int     @default(0)
  scenes    Scene[]
  createdAt DateTime @default(now())

  @@map("scene_category")
}

model Scene {
  id                   String             @id @default(cuid())
  category             SceneCategory      @relation(fields: [categoryId], references: [id])
  categoryId           String
  title                String
  location             String
  description          String?
  requiredOutputLevel  String             @default("L1")
  requiredUserLevel    Int                @default(1)
  isFree               Boolean            @default(false)  // 免费用户可访问
  prerequisiteScenes   ScenePrerequisite[] @relation("Scene")
  prerequisiteFor      ScenePrerequisite[] @relation("Prerequisite")
  vocabularies         SceneVocabulary[]
  chunks               Chunk[]
  trainingTopics       TrainingTopic[]
  scriptEpisodes       ScriptEpisode[]
  chunkExamples        ChunkExample[]
  userProgresses       UserSceneProgress[]
  gameLocations        GameLocation[]
  createdAt            DateTime           @default(now())

  @@map("scene")
}

model ScenePrerequisite {
  id             String @id @default(cuid())
  scene          Scene  @relation("Scene", fields: [sceneId], references: [id])
  sceneId        String
  prerequisite   Scene  @relation("Prerequisite", fields: [prerequisiteId], references: [id])
  prerequisiteId String

  @@unique([sceneId, prerequisiteId])
  @@map("scene_prerequisite")
}

// ──── Chunk 表达块 ────

model Chunk {
  id                  String              @id @default(cuid())
  text                String
  meaning             String
  description         String?             @db.Text
  category            String
  difficulty          String              @default("L2")
  examples            ChunkExample[]
  scene               Scene?              @relation(fields: [sceneId], references: [id])
  sceneId             String?
  applicableSceneIds  String[]
  userProgresses      UserChunkProgress[]
  scriptEpisodeChunks ScriptEpisodeChunk[]
  topicChunks         TrainingTopicChunk[]
  createdAt           DateTime            @default(now())

  @@index([sceneId])
  @@index([difficulty])
  @@map("chunk")
}

model SceneVocabulary {
  id            String               @id @default(cuid())
  scene         Scene                @relation(fields: [sceneId], references: [id])
  sceneId       String
  word          String
  meaning       String               // 中文释义
  partOfSpeech  String?              // 词性：noun/verb/adj/phrase
  phoneticUs    String?              // 美式音标
  phoneticUk    String?              // 英式音标
  audioUsUrl    String?              // 美式发音音频
  audioUkUrl    String?              // 英式发音音频
  definitionEn  String?              @db.Text  // 英文释义
  synonyms      String[]             @default([])  // 同义词
  examples      Json?                // 例句 [{ en, zh, note? }]
  description   String?              @db.Text  // 用法讲解/搭配说明
  difficulty    String               @default("L1")  // L1~L5
  sortOrder     Int                  @default(0)
  episodeVocabs ScriptEpisodeVocab[]

  @@index([sceneId])
  @@map("scene_vocabulary")
}

model ChunkExample {
  id        String   @id @default(cuid())
  chunk     Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  chunkId   String
  en        String   @db.Text
  zh        String   @db.Text
  note      String?  @db.Text
  level     String   @default("basic")
  scene     Scene?   @relation(fields: [sceneId], references: [id])
  sceneId   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([chunkId, sortOrder])
  @@index([sceneId])
  @@map("chunk_example")
}

// ──── 用户 Chunk 掌握度 ────

model UserChunkProgress {
  id              String             @id @default(cuid())
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  chunk           Chunk              @relation(fields: [chunkId], references: [id])
  chunkId         String
  status          ChunkMasteryStatus @default(not_learned)
  seenCount       Int                @default(0)
  spokenCount     Int                @default(0)
  correctUseCount Int                @default(0)
  usedSceneIds    String[]           @default([])
  lastPracticedAt DateTime?
  updatedAt       DateTime           @updatedAt

  @@unique([userId, chunkId])
  @@map("user_chunk_progress")
}

// ──── 训练话题 ────

model TrainingTopic {
  id                   String            @id @default(cuid())
  scene                Scene             @relation(fields: [sceneId], references: [id])
  sceneId              String
  title                String
  description          String?           @db.Text
  knowledgePoints      String?           @db.Text
  promptEn             String            @db.Text
  promptZh             String            @db.Text
  suggestedDurationSec Int               @default(60)
  difficulty           String            @default("L2")
  activeChunks         TrainingTopicChunk[]
  sentencePatterns     TrainingTopicSentencePattern[]
  practiceSessions     PracticeSession[]
  sentencePatternsDeprecated     Json?    @map("sentence_patterns")
  inkScriptId          String?           @unique
  inkScript            InkScript?        @relation("TopicInkScript", fields: [inkScriptId], references: [id])
  sortOrder            Int               @default(0)
  createdAt            DateTime          @default(now())

  @@index([sceneId, difficulty])
  @@map("training_topic")
}

model TrainingTopicSentencePattern {
  id         String        @id @default(cuid())
  topic      TrainingTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId    String
  pattern    String
  meaning    String?
  slots      Json?
  example    String?
  difficulty String        @default("L1")
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([topicId, sortOrder])
  @@map("training_topic_sentence_pattern")
}

model PracticeSession {
  id                       String         @id @default(cuid())
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   String
  topic                    TrainingTopic  @relation(fields: [topicId], references: [id])
  topicId                  String
  sceneId                  String
  inkScriptId              String?
  status                   String         @default("active")
  topicSnapshot            Json
  sceneSnapshot            Json
  objectivesSnapshot       Json
  chunksSnapshot           Json
  vocabSnapshot            Json
  sentencePatternsSnapshot Json?
  turnCount                Int            @default(0)
  analysisResult           Json?
  analysisRaw              String?        @db.Text
  analysisError            String?        @db.Text
  startedAt                DateTime       @default(now())
  completedAt              DateTime?
  analyzedAt               DateTime?
  updatedAt                DateTime       @updatedAt
  turns                    PracticeTurn[]

  @@index([userId, startedAt(sort: Desc)])
  @@index([topicId, startedAt(sort: Desc)])
  @@index([status])
  @@map("practice_session")
}

model PracticeTurn {
  id                 String          @id @default(cuid())
  session            PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId          String
  round              Int
  npcText            String          @db.Text
  userText           String          @db.Text
  userAudioUrl       String?
  inputNodeId        String?
  tags               Json?
  judgement          Json?
  objectivesCompleted String[]       @default([])
  chunksUsed         String[]        @default([])
  createdAt          DateTime        @default(now())

  @@index([sessionId, round])
  @@map("practice_turn")
}

model TrainingTopicChunk {
  id        String        @id @default(cuid())
  topic     TrainingTopic @relation(fields: [topicId], references: [id])
  topicId   String
  chunk     Chunk         @relation(fields: [chunkId], references: [id])
  chunkId   String
  sortOrder Int           @default(0)

  @@unique([topicId, chunkId])
  @@map("training_topic_chunk")
}

// ──── 剧本系统 ────

model ScriptEpisode {
  id                   String                 @id @default(cuid())
  chapterId            String
  chapterTitle         String
  episodeOrder         Int
  title                String
  description          String?                @db.Text
  scene                Scene                  @relation(fields: [sceneId], references: [id])
  sceneId              String
  requiredOutputLevel  String                 @default("L2")
  requiredUserLevel    Int                    @default(1)
  vocabRequiredCount   Int                    @default(6)
  vocabTotalCount      Int                    @default(10)
  chunkRequiredCount   Int                    @default(6)
  chunkTotalCount      Int                    @default(10)
  prerequisiteEpisodes String[]               @default([])
  objectives           String[]
  passObjectiveCount   Int                    @default(3)
  passChunkCount       Int                    @default(3)
  passRetellRequired   Boolean                @default(true)
  passMinDialogues     Int                    @default(3)
  rewards              Json?
  npcName              String
  npcRole              String
  npcPersonality       String?
  inkScriptId          String?
  coreVocabularies     ScriptEpisodeVocab[]
  coreChunks           ScriptEpisodeChunk[]
  dialogues            ScriptDialogue[]
  records              ScriptRecord[]
  isPreview            Boolean                @default(false)
  createdAt            DateTime               @default(now())

  @@index([chapterId, episodeOrder])
  @@map("script_episode")
}

model ScriptEpisodeVocab {
  id        String        @id @default(cuid())
  episode   ScriptEpisode @relation(fields: [episodeId], references: [id])
  episodeId String
  vocab     SceneVocabulary @relation(fields: [vocabId], references: [id])
  vocabId   String
  sortOrder Int           @default(0)

  @@unique([episodeId, vocabId])
  @@map("script_episode_vocab")
}

model ScriptEpisodeChunk {
  id        String        @id @default(cuid())
  episode   ScriptEpisode @relation(fields: [episodeId], references: [id])
  episodeId String
  chunk     Chunk         @relation(fields: [chunkId], references: [id])
  chunkId   String
  sortOrder Int           @default(0)

  @@unique([episodeId, chunkId])
  @@map("script_episode_chunk")
}

// ──── 剧本对话/通关记录 ────

model ScriptDialogue {
  id                 String         @id @default(cuid())
  episode            ScriptEpisode  @relation(fields: [episodeId], references: [id])
  episodeId          String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  round              Int
  npcText            String         @db.Text
  userAudioUrl       String?
  userText           String?        @db.Text
  isOnTopic          Boolean?
  objectiveCompleted String[]       @default([])
  chunksUsed         String[]       @default([])
  grammarIssues      Json?
  needsFollowUp      Boolean        @default(false)
  createdAt          DateTime       @default(now())

  @@index([episodeId, userId, round])
  @@map("script_dialogue")
}

model ScriptRecord {
  id              String         @id @default(cuid())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  episode         ScriptEpisode  @relation(fields: [episodeId], references: [id])
  episodeId       String
  passed          Boolean        @default(false)
  objectivesDone  Int            @default(0)
  chunksUsed      Int            @default(0)
  dialogueRounds  Int            @default(0)
  retellCompleted Boolean        @default(false)
  aiFeedback      Json?
  xpEarned        Int            @default(0)
  completedAt     DateTime?
  createdAt       DateTime       @default(now())

  @@unique([userId, episodeId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("script_record")
}

// ──── 表达库 & 复习 ────

model ExpressionItem {
  id             String         @id @default(cuid())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  type           ExpressionType @default(chunk)
  original       String?        @db.Text
  corrected      String?        @db.Text
  chunkText      String?
  sceneName      String?
  masteryStatus  String         @default("learning")
  reviewCount    Int            @default(0)
  easeFactor     Float          @default(2.5)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  createdAt      DateTime       @default(now())

  @@index([userId, type])
  @@index([userId, masteryStatus])
  @@map("expression_item")
}

// ──── 用户场景熟练度 ────

model UserSceneProgress {
  id                     String   @id @default(cuid())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String
  scene                  Scene    @relation(fields: [sceneId], references: [id])
  sceneId                String
  readiness              Int      @default(0)
  mastery                Int      @default(0)
  vocabLearned           Int      @default(0)
  vocabTotal             Int      @default(0)
  chunkMastered          Int      @default(0)
  chunkTotal             Int      @default(0)
  completedPracticeCount Int      @default(0)
  completedScriptCount   Int      @default(0)
  prerequisiteCompleted  Boolean  @default(false)
  updatedAt              DateTime @updatedAt

  @@unique([userId, sceneId])
  @@map("user_scene_progress")
}

// ──── 新手引导 ────

model OnboardingStatus {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @unique
  goalsSelected   Boolean  @default(false)
  abilitySelected Boolean  @default(false)
  diagnosticDone  Boolean  @default(false)
  tutorialDone    Boolean  @default(false)
  diagnosticResult Json?
  createdAt       DateTime @default(now())

  @@map("onboarding_status")
}

// ──── 探索模式（视觉小说架构）───

model GameCharacter {
  id              String            @id @default(cuid())
  name            String
  displayName     String
  role            String
  personality     String?
  avatarUrl       String?
  spriteBaseUrl   String?
  expressions     Json?
  defaultPosition String?
  ttsVoice        String?           // TTS 音色 ID（如 MiniMax/Cartesia voice ID）
  locationNpcs    GameLocationNpc[]
  explorationRecords ExplorationRecord[]
  createdAt       DateTime          @default(now())

  @@map("game_character")
}

model GameMap {
  id                  String         @id @default(cuid())
  name                String
  displayName         String
  backgroundUrl       String?
  thumbnailUrl        String?
  width               Int            @default(1920)
  height              Int            @default(1080)
  locations           GameLocation[]
  requiredOutputLevel String         @default("L1")
  requiredChapterId   String?
  isPreview           Boolean        @default(false)
  sortOrder           Int            @default(0)
  createdAt           DateTime       @default(now())

  @@map("game_map")
}

model GameLocation {
  id                   String             @id @default(cuid())
  map                  GameMap            @relation(fields: [mapId], references: [id])
  mapId                String
  name                 String
  displayName          String
  description          String?
  posX                 Float              @default(0)
  posY                 Float              @default(0)
  icon                 String?
  backgroundUrl        String?
  bgmUrl               String?
  ambientUrl           String?
  locationType         String             @default("vn_scene")
  sceneId              String?
  scene                Scene?             @relation(fields: [sceneId], references: [id])
  inkScriptId          String?
  npcs                 GameLocationNpc[]
  exits                GameLocationExit[]  @relation("FromLocation")
  incomingExits        GameLocationExit[]  @relation("ToLocation")
  explorationRecords   ExplorationRecord[]
  requiredOutputLevel  String             @default("L1")
  requiredSceneIds     String[]           @default([])
  requiredFlags        Json?
  isPreview            Boolean            @default(false)
  sortOrder            Int                @default(0)
  createdAt            DateTime           @default(now())

  @@map("game_location")
}

model GameLocationExit {
  id            String       @id @default(cuid())
  from          GameLocation @relation("FromLocation", fields: [fromId], references: [id])
  fromId        String
  to            GameLocation @relation("ToLocation", fields: [toId], references: [id])
  toId          String
  label         String
  requiredFlags Json?

  @@unique([fromId, toId])
  @@map("game_location_exit")
}

model GameLocationNpc {
  id               String        @id @default(cuid())
  location         GameLocation  @relation(fields: [locationId], references: [id])
  locationId       String
  character        GameCharacter @relation(fields: [characterId], references: [id])
  characterId      String
  schedule         Json?
  defaultGreeting  String?
  inkTalkScriptId  String?
  sortOrder        Int           @default(0)

  @@unique([locationId, characterId])
  @@map("game_location_npc")
}

// ──── Ink 叙事脚本 & 游戏存档 ────

model InkScript {
  id                String          @id @default(cuid())
  key               String          @unique
  title             String
  scriptType        String          @default("episode")
  inkJson           Json?
  inkSource         String?         @db.Text
  episodeId         String?
  locationId        String?
  characterId       String?
  topicId           String?
  trainingTopic     TrainingTopic?  @relation("TopicInkScript")
  declaredVariables Json?
  version           Int             @default(1)
  changelog         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([scriptType])
  @@index([episodeId])
  @@index([locationId])
  @@map("ink_script")
}

model GameSave {
  id                String   @id @default(cuid())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  inkState          Json?
  currentMapId      String?
  currentLocationId String?
  visitedLocationIds String[] @default([])
  flags             Json?
  saveName          String   @default("自动存档")
  playTimeSeconds   Int      @default(0)
  slot              Int      @default(1)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([userId, slot])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("game_save")
}

model ExplorationRecord {
  id           String        @id @default(cuid())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  character    GameCharacter @relation(fields: [characterId], references: [id])
  characterId  String
  location     GameLocation  @relation(fields: [locationId], references: [id])
  locationId   String
  userText     String        @db.Text
  npcReply     String?       @db.Text
  feedback     Json?
  isInkDriven  Boolean       @default(false)
  inkKnotName  String?
  createdAt    DateTime      @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@map("exploration_record")
}

// ──── 成就 V2 系统 ────

model AchievementDef {
  id              String              @id @default(cuid())
  key             String              @unique
  title           String
  description     String
  category        AchievementCategory @default(milestone)
  rarity          AchievementRarity   @default(common)
  icon            String?
  condition       Json
  rewardXp        Int                 @default(0)
  rewardTitle     String?
  sortOrder       Int                 @default(0)
  isHidden        Boolean             @default(false)
  hintText        String?
  createdAt       DateTime            @default(now())
  userAchievements UserAchievementV2[]

  @@map("achievement_def")
}

model UserAchievementV2 {
  id              String                 @id @default(cuid())
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  achievement     AchievementDef         @relation(fields: [achievementId], references: [id])
  achievementId   String
  status          UserAchievementStatus  @default(locked)
  progress        Int                    @default(0)
  progressTarget  Int                    @default(0)
  unlockedAt      DateTime?
  seenAt          DateTime?
  createdAt       DateTime               @default(now())

  @@unique([userId, achievementId])
  @@index([userId, status])
  @@map("user_achievement_v2")
}

// ── 积分系统 ──

model UserCheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  points    Int      @default(10)
  streak    Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@map("user_check_in")
}

model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  amount      Int
  balance     Int
  description String?
  referenceId String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("point_transaction")
}

// ── AI 额度追踪 ──

model AiUsageDaily {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date

  feedback Int      @default(0)   // 纠错反馈次数
  dialogue Int      @default(0)   // 对话判定次数
  summary  Int      @default(0)   // 汇总/分析次数

  @@unique([userId, date])
  @@index([userId])
  @@map("ai_usage_daily")
}
