// ──── 故事剧情系统 ────

model StoryEpisode {
  id                      String                        @id @default(cuid())
  chapterKey              String                        @map("chapterId")
  chapterName             String                        @map("chapterTitle")
  sortOrder               Int                           @map("episodeOrder")
  title                   String
  description             String?                       @db.Text
  scene                   Scene                         @relation(fields: [sceneId], references: [id])
  sceneId                 String
  requiredOutputLevel     String                        @default("L2")
  requiredUserLevel       Int                           @default(1)
  requiredVocabularyCount Int                           @default(6) @map("vocabRequiredCount")
  totalVocabularyCount    Int                           @default(10) @map("vocabTotalCount")
  requiredChunkCount      Int                           @default(6) @map("chunkRequiredCount")
  totalChunkCount         Int                           @default(10) @map("chunkTotalCount")
  prerequisiteEpisodeIds  String[]                      @default([]) @map("prerequisiteEpisodes")
  objectives              String[]
  requiredObjectiveCount  Int                           @default(3) @map("passObjectiveCount")
  requiredUsedChunkCount  Int                           @default(3) @map("passChunkCount")
  requiresRetell          Boolean                       @default(true) @map("passRetellRequired")
  minimumTurnCount        Int                           @default(3) @map("passMinDialogues")
  rewards                 Json?
  characterName           String                        @map("npcName")
  characterRole           String                        @map("npcRole")
  characterPersona        String?                       @map("npcPersonality")
  inkScriptId             String?
  vocabularies            StoryEpisodeVocabulary[]
  chunks                  StoryEpisodeChunk[]
  sentencePatterns        StoryEpisodeSentencePattern[]
  turns                   StoryTurn[]
  records                 StoryRecord[]
  isPreview               Boolean                       @default(false)
  createdAt               DateTime                      @default(now())

  @@index([chapterKey, sortOrder], map: "script_episode_chapterId_episodeOrder_idx")
  @@map("script_episode")
}

model StoryEpisodeVocabulary {
  id         String       @id @default(cuid())
  episode    StoryEpisode @relation(fields: [episodeId], references: [id])
  episodeId  String
  vocabulary Vocabulary   @relation(fields: [vocabId], references: [id])
  vocabId    String
  sortOrder  Int          @default(0)

  @@unique([episodeId, vocabId])
  @@map("script_episode_vocab")
}

model StoryEpisodeChunk {
  id        String       @id @default(cuid())
  episode   StoryEpisode @relation(fields: [episodeId], references: [id])
  episodeId String
  chunk     Chunk        @relation(fields: [chunkId], references: [id])
  chunkId   String
  sortOrder Int          @default(0)

  @@unique([episodeId, chunkId])
  @@map("script_episode_chunk")
}

model StoryEpisodeSentencePattern {
  id        String          @id @default(cuid())
  episode   StoryEpisode    @relation(fields: [episodeId], references: [id])
  episodeId String
  pattern   SentencePattern @relation(fields: [patternId], references: [id])
  patternId String
  sortOrder Int             @default(0)

  @@unique([episodeId, patternId])
  @@map("script_episode_sentence_pattern")
}

// ──── 故事对话/通关记录 ────

