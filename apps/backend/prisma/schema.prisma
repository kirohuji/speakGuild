generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

model User {
  id                  String    @id
  name                String
  email               String
  emailVerified       Boolean   @default(false)
  image               String?
  username            String?   @unique
  phoneNumber         String?   @unique
  phoneNumberVerified Boolean   @default(false)
  role                UserRole  @default(user)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions            Session[]
  accounts            Account[]
  bindingConfig       UserBindingConfig?
  favoriteQuestions   FavoriteQuestion[]
  vocabularyWords     VocabularyWord[]
  practiceRecords     PracticeRecord[]
  practiceProgresses  PracticeProgress[]
  mockExamRecords     MockExamRecord[]
  dailyActivities     DailyActivity[]
  userPreference      UserPreference?
  fileReferences      FileReference[]
  notificationReads   NotificationRead[]
  notificationTargets NotificationTarget[]
  sentNotifications   Notification[]
  orders              Order[]
  membership          UserMembership?
  referralCode        ReferralCode?
  referredBy          Referral?
  achievements        UserAchievement[]
  feedbacks           Feedback[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---- 题库域 ----

model QuestionBank {
  id            String   @id @default(cuid())
  name          String
  province      String
  language      String
  examType      String
  interviewForm String
  status        String   @default("active")
  topics        QuestionTopic[]
  userBindings  UserBindingConfig[]
  mockPapers    MockPaper[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@map("question_bank")
}

model QuestionTopic {
  id        String   @id @default(cuid())
  bank      QuestionBank @relation(fields: [bankId], references: [id])
  bankId    String
  code      String
  name      String
  sortOrder Int      @default(0)
  items     QuestionItem[]
  @@map("question_topic")
}

model QuestionItem {
  id                   String   @id @default(cuid())
  topic                QuestionTopic @relation(fields: [topicId], references: [id])
  topicId              String
  title                String
  difficulty           Int      @default(3)
  suggestedDurationSec Int      @default(120)
  masteryScore         Int      @default(0)
  keywords             String[]
  focusWords           String[]
  content              QuestionContent?
  favorites            FavoriteQuestion[]
  practiceRecords      PracticeRecord[]
  practiceProgresses   PracticeProgress[]
  mockPaperQuestions   MockPaperQuestion[]
  vocabularyWords      VocabularyWord[]
  questionAudios       QuestionAudio[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([topicId, difficulty])
  @@map("question_item")
}

model QuestionContent {
  id         String   @id @default(cuid())
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String   @unique
  promptEn   String   @db.Text
  promptZh   String   @db.Text
  answerEn   String   @db.Text
  answerZh   String   @db.Text
  summary    String   @db.Text
  @@map("question_content")
}

// ---- 学习行为域 ----

model UserBindingConfig {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String   @unique
  province      String
  language      String
  examType      String
  interviewForm String
  bank          QuestionBank? @relation(fields: [bankId], references: [id])
  bankId        String?
  updatedAt     DateTime @updatedAt
  @@map("user_binding_config")
}

model FavoriteQuestion {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String
  createdAt  DateTime @default(now())
  @@unique([userId, questionId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("favorite_question")
}

model VocabularyWord {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  term             String
  definition       String?
  sourceQuestion   QuestionItem? @relation(fields: [sourceQuestionId], references: [id])
  sourceQuestionId String?
  createdAt        DateTime @default(now())
  @@unique([userId, term])
  @@index([userId, createdAt(sort: Desc)])
  @@map("vocabulary_word")
}

model PracticeRecord {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String
  actionType String
  payload    Json?
  createdAt  DateTime @default(now())
  @@index([userId, createdAt(sort: Desc)])
  @@map("practice_record")
}

model PracticeProgress {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  question     QuestionItem @relation(fields: [questionId], references: [id])
  questionId   String
  masteryScore Int      @default(0)
  seenAt       DateTime?
  updatedAt    DateTime @updatedAt
  @@unique([userId, questionId])
  @@map("practice_progress")
}

// ---- 模考域 ----

model MockPaper {
  id               String   @id @default(cuid())
  bank             QuestionBank @relation(fields: [bankId], references: [id])
  bankId           String
  title            String
  paperType        String   @default("standard")
  suggestedMinutes Int      @default(30)
  focus            String[]
  questions        MockPaperQuestion[]
  examRecords      MockExamRecord[]
  createdAt        DateTime @default(now())
  @@map("mock_paper")
}

model MockPaperQuestion {
  id         String   @id @default(cuid())
  paper      MockPaper @relation(fields: [paperId], references: [id])
  paperId    String
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String
  sortOrder  Int      @default(0)
  @@map("mock_paper_question")
}

model MockExamRecord {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  paper    MockPaper @relation(fields: [paperId], references: [id])
  paperId  String
  score    Int
  weakness String[]
  takenAt  DateTime @default(now())
  @@index([userId, takenAt(sort: Desc)])
  @@map("mock_exam_record")
}

// ---- 用户看板域 ----

model DailyActivity {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  date     DateTime @db.Date
  count    Int      @default(1)
  @@unique([userId, date])
  @@map("daily_activity")
}

model UserPreference {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  autoPlay  Boolean  @default(false)
  language  String   @default("zh-CN")
  theme     String   @default("system")
  updatedAt DateTime @updatedAt
  @@map("user_preference")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @default("")
  group       String   @default("basic")
  label       String   @default("")
  type        String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt
  @@map("system_config")
}

enum MembershipLevel {
  free
  standard
  advanced
}

model MembershipPlan {
  id                       String           @id @default(cuid())
  name                     String
  level                    MembershipLevel  @default(standard)
  price                    Int              /// 月付价格（分）
  yearlyPrice              Int?             /// 年付价格（分）
  period                   String
  durationDays             Int              @default(30)
  features                 String[]
  revenueCatEntitlementId  String?          /// RevenueCat 权益 ID（跨端同步用）
  highlighted              Boolean          @default(false)
  sortOrder                Int              @default(0)
  orders                   Order[]
  memberships              UserMembership[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  @@map("membership_plan")
}

/// 支付订单
enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum PaymentMethod {
  alipay
  wechat
}

model Order {
  id            String        @id @default(cuid())
  orderNo       String        @unique /// 商户订单号
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  plan          MembershipPlan @relation(fields: [planId], references: [id])
  planId        String
  amount        Int           /// 实付金额（分）
  paymentMethod PaymentMethod
  status        OrderStatus   @default(pending)
  paymentRef    String?       /// 支付网关交易号
  billingCycle  String        @default("monthly") /// monthly | yearly
  paidAt        DateTime?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  membership    UserMembership?
  coupon        Coupon?         @relation(fields: [couponId], references: [id])
  couponId      String?

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("order")
}

/// 用户会员状态
enum MembershipStatus {
  active
  expired
  cancelled
}

model UserMembership {
  id            String           @id @default(cuid())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String           @unique
  plan          MembershipPlan   @relation(fields: [planId], references: [id])
  planId        String
  status        MembershipStatus @default(active)
  order         Order?           @relation(fields: [orderId], references: [id])
  orderId        String?          @unique
  rcCustomerId  String?          /// RevenueCat 用户 ID（跨端同步）
  startedAt     DateTime         @default(now())
  expiredAt     DateTime
  autoRenew     Boolean          @default(false)
  cancelledAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status, expiredAt])
  @@map("user_membership")
}

// ---- 文件资产域 ----

enum FileAssetGroup {
  avatar
  library
  tts
  notification
}

enum FileAssetStatus {
  active
  deleted
}

model FileAsset {
  id               String          @id @default(cuid())
  sha256           String          @unique
  bucket           String
  region           String
  cosKey           String          @unique
  group            FileAssetGroup
  size             Int
  mimeType         String
  filename         String
  status           FileAssetStatus @default(active)
  refCount         Int             @default(0)
  lastReferencedAt DateTime?
  createdAt        DateTime        @default(now())
  references       FileReference[]
  questionAudios   QuestionAudio[]
  resourceNodes    ResourceNode[]
  @@index([group, status, createdAt(sort: Desc)])
  @@index([status, refCount, createdAt])
  @@map("file_asset")
}

model FileReference {
  id        String    @id @default(cuid())
  asset     FileAsset @relation(fields: [assetId], references: [id])
  assetId   String
  bizType   String
  bizId     String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime  @default(now())
  @@unique([assetId, bizType, bizId, userId])
  @@index([bizType, bizId, userId])
  @@map("file_reference")
}

// ---- 资料库域 ----

enum ResourceNodeType {
  folder
  video_url
  video
  audio
  pdf
  image
  document
  other
}

/// 资料库节点（统一管理文件夹和资源项的树形结构）
model ResourceNode {
  id        String           @id @default(cuid())
  parent    ResourceNode?    @relation("ResourceTree", fields: [parentId], references: [id])
  parentId  String?
  children  ResourceNode[]   @relation("ResourceTree")
  name      String
  type      ResourceNodeType
  region    String?          /// 地区标识（null = 通用资料，适用于所有地区）
  asset     FileAsset?       @relation(fields: [assetId], references: [id])
  assetId   String?          /// 关联 COS 文件（video/audio/pdf/image/document/other 类型）
  url       String?          /// 外部链接（video_url 类型使用）
  description String?        @db.Text
  mimeType  String?          /// 文件 MIME 类型（冗余，方便前端展示图标）
  fileSize  Int?             /// 文件大小（冗余，方便前端展示）
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([parentId, sortOrder])
  @@index([region])
  @@index([type])
  @@map("resource_node")
}

// ---- TTS 音频缓存域 ----

enum TtsProvider {
  minimax
  cartesia
}

/// 题目音频缓存：同一题目 + 相同配置只生成一次，之后直接复用
model QuestionAudio {
  id             String      @id @default(cuid())
  question       QuestionItem @relation(fields: [questionId], references: [id])
  questionId     String
  /// provider+model+voiceId+params 的 SHA1 哈希，保证唯一性
  configHash     String
  provider       TtsProvider
  model          String
  voiceId        String?
  mimeType       String
  asset          FileAsset   @relation(fields: [assetId], references: [id])
  assetId        String
  wordTimestamps Json?
  createdAt      DateTime    @default(now())
  @@unique([questionId, configHash])
  @@index([questionId])
  @@index([assetId])
  @@map("question_audio")
}

// ---- 消息通知域 ----

enum NotificationType {
  broadcast
  targeted
}

model Notification {
  id        String              @id @default(cuid())
  title     String
  content   String              @db.Text /// Markdown 格式内容
  type      NotificationType
  sentBy    User                @relation(fields: [sentById], references: [id])
  sentById  String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  reads     NotificationRead[]
  targets   NotificationTarget[]
  @@index([type, createdAt(sort: Desc)])
  @@map("notification")
}

model NotificationRead {
  id             String       @id @default(cuid())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  readAt         DateTime     @default(now())
  @@unique([notificationId, userId])
  @@index([userId, readAt(sort: Desc)])
  @@map("notification_read")
}

model NotificationTarget {
  id             String       @id @default(cuid())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_target")
}

// ──── 优惠券/促销域 ────

enum CouponType {
  percentage
  fixed
  free_trial
}

model Coupon {
  id          String      @id @default(cuid())
  code        String      @unique
  type        CouponType
  value       Float       /// 折扣值（百分比如20=20%，固定金额单位分，试用天数）
  minAmount   Float?      /// 最低消费金额（分）
  maxUses     Int?
  usedCount   Int         @default(0)
  validFrom   DateTime    @default(now())
  validUntil  DateTime?
  isActive    Boolean     @default(true)
  orders      Order[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("coupon")
}

// ──── 邀请域 ────

model ReferralCode {
  id           String     @id @default(cuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code         String     @unique
  totalInvited Int        @default(0)
  totalReward  Int        @default(0)
  createdAt    DateTime   @default(now())
  referrals    Referral[]

  @@map("referral_code")
}

model Referral {
  id             String       @id @default(cuid())
  referrerId     String
  referrer       ReferralCode @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String       @unique
  referredUser   User         @relation(fields: [referredUserId], references: [id], onDelete: Cascade)
  rewardedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([referrerId])
  @@map("referral")
}

// ──── 成就域 ────

model Achievement {
  id          String             @id @default(cuid())
  key         String             @unique
  name        String
  description String
  icon        String
  category    String
  condition   Json
  sortOrder   Int                @default(0)
  users       UserAchievement[]
  createdAt   DateTime           @default(now())

  @@map("achievement")
}

model UserAchievement {
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@id([userId, achievementId])
  @@index([userId])
  @@map("user_achievement")
}

// ──── 反馈域 ────

enum FeedbackStatus {
  pending
  resolved
  closed
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  content   String         @db.Text
  contact   String?
  status    FeedbackStatus @default(pending)
  adminNote String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("feedback")
}
