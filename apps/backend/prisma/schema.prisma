generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

model User {
  id                     String               @id
  name                   String
  email                  String
  emailVerified          Boolean              @default(false)
  image                  String?
  username               String?              @unique
  phoneNumber            String?              @unique
  phoneNumberVerified    Boolean              @default(false)
  role                   UserRole             @default(user)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletionRequestedAt    DateTime?
  deletionScheduledAt    DateTime?
  hasCompletedOnboarding Boolean              @default(false)
  sessions               Session[]
  accounts               Account[]
  dailyActivities        DailyActivity[]
  userPreference         UserPreference?
  fileReferences         FileReference[]
  notificationReads      NotificationRead[]
  notificationTargets    NotificationTarget[]
  sentNotifications      Notification[]
  orders                 Order[]
  membership             UserMembership?
  referralCode           ReferralCode?
  referredBy             Referral?
  feedbacks              Feedback[]

  // --- English Output Training: 用户画像扩展 ---
  learningGoals      String[]            @default([])
  outputLevel        String              @default("L1")
  outputLevelDetail  Json?
  totalXp            Int                 @default(0)
  points             Int                 @default(0)
  userLevel          Int                 @default(1)
  sceneProgresses    UserSceneProgress[]
  chunkProgresses    UserChunkProgress[]
  expressionItems    ExpressionItem[]
  storyRecords       StoryRecord[]
  storyTurns         StoryTurn[]
  practiceSessions   PracticeSession[]
  warmupItemProgresses UserWarmupItemProgress[]
  dailyPracticeRuns    UserDailyPracticeRun[]
  dailyPracticeAttempts UserDailyPracticeAttempt[]
  explorationRecords ExplorationRecord[]
  userAchievementsV2 UserAchievementV2[]
  gameSaves          GameSave[]
  checkIns           UserCheckIn[]
  pointTransactions  PointTransaction[]
  aiUsages           AiUsageDaily[]

  @@unique([email])
  @@index([deletionScheduledAt])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---- 用户看板域 ----

model DailyActivity {
  id     String   @id @default(cuid())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  date   DateTime @db.Date
  count  Int      @default(1)

  @@unique([userId, date])
  @@map("daily_activity")
}

model UserPreference {
  id            String       @id @default(cuid())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String       @unique
  autoPlay      Boolean      @default(false)
  language      String       @default("zh-CN")
  theme         String       @default("system")
  themePresetId String?
  themePreset   ThemePreset? @relation(fields: [themePresetId], references: [id], onDelete: SetNull)
  updatedAt     DateTime     @updatedAt

  @@map("user_preference")
}

// ── 沉浸式主题套装 ──
model ThemePreset {
  id          String  @id @default(cuid())
  name        String // 主题名称
  description String? // 描述
  sortOrder   Int     @default(0) // 排序
  isActive    Boolean @default(true) // 是否启用
  isDefault   Boolean @default(false) // 是否默认主题

  // 背景类型: gradient | image | video
  bgType String @default("gradient")

  // ── Light 模式色板（JSON: { background, foreground, primary, card, muted, accent, border ... }）──
  lightColors      Json?
  // ── Light 模式背景（CSS gradient string 或图片 URL）──
  lightBackground  String? @db.Text
  // ── Light 模式装饰配置（JSON: [{ type, color, position, size, blur, animation }]）──
  lightDecorations Json?

  // ── Dark 模式（同上）──
  darkColors      Json?
  darkBackground  String? @db.Text
  darkDecorations Json?

  // ── 音效 ──
  bgmUrl    String? // 背景音效 URL（COS 上）
  bgmVolume Float   @default(0.3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPreferences UserPreference[]

  @@map("theme_preset")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @default("")
  group       String   @default("basic")
  label       String   @default("")
  type        String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

/// AI 供应商配置：管理 STT / TTS / LLM 各类模型供应商的参数
model AiProvider {
  id        String   @id @default(cuid())
  type      String   /// stt | tts | llm
  provider  String   /// 供应商标识: whisper | tencent | minimax | cartesia | deepseek | openai
  label     String   /// 显示名称
  model     String   @default("") /// 默认模型名
  apiKey    String   @default("") /// API 密钥
  baseUrl   String   @default("") /// API 基础地址
  config    Json?    /// 供应商特定配置: { temperature?, enableTimestamps?, ... }
  isActive  Boolean  @default(false) /// 是否为该类型当前激活的供应商
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, provider])
  @@map("ai_provider")
}

/// 每日一句：按日期管理的每日句子（首页展示）
model DailySentence {
  id          String   @id @default(cuid())
  date        DateTime @unique /// 句子所属日期（仅日期部分有效）
  quote       String /// 英文句子
  translation String /// 中文翻译
  author      String   @default("") /// 出处/作者
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, sortOrder])
  @@map("daily_sentence")
}

enum MembershipLevel {
  free
  standard
  advanced
}

model MembershipPlan {
  id                      String           @id @default(cuid())
  name                    String
  level                   MembershipLevel  @default(standard)
  price                   Int /// 月付价格（分）
  yearlyPrice             Int? /// 年付价格（分）
  period                  String
  durationDays            Int              @default(30)
  features                String[]
  revenueCatEntitlementId String? /// RevenueCat 权益 ID（跨端同步用）
  highlighted             Boolean          @default(false)
  sortOrder               Int              @default(0)
  orders                  Order[]
  memberships             UserMembership[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@map("membership_plan")
}

/// 支付订单
enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum PaymentMethod {
  alipay
  wechat
}

model Order {
  id            String          @id @default(cuid())
  orderNo       String          @unique /// 商户订单号
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  plan          MembershipPlan  @relation(fields: [planId], references: [id])
  planId        String
  amount        Int /// 实付金额（分）
  paymentMethod PaymentMethod
  status        OrderStatus     @default(pending)
  paymentRef    String? /// 支付网关交易号
  billingCycle  String          @default("monthly") /// monthly | yearly
  paidAt        DateTime?
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  membership    UserMembership?
  coupon        Coupon?         @relation(fields: [couponId], references: [id])
  couponId      String?

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("order")
}

/// 用户会员状态
enum MembershipStatus {
  active
  expired
  cancelled
}

model UserMembership {
  id           String           @id @default(cuid())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String           @unique
  plan         MembershipPlan   @relation(fields: [planId], references: [id])
  planId       String
  status       MembershipStatus @default(active)
  order        Order?           @relation(fields: [orderId], references: [id])
  orderId      String?          @unique
  rcCustomerId String? /// RevenueCat 用户 ID（跨端同步）
  startedAt    DateTime         @default(now())
  expiredAt    DateTime
  autoRenew    Boolean          @default(false)
  cancelledAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, expiredAt])
  @@map("user_membership")
}

// ---- 文件资产域 ----

enum FileAssetGroup {
  avatar
  library
  tts
  notification
  mobile_bundle
  learning_pack
  learning_pack_delta
  user_recording
}

enum FileAssetStatus {
  active
  deleted
}

model FileAsset {
  id               String            @id @default(cuid())
  sha256           String            @unique
  bucket           String
  region           String
  cosKey           String            @unique
  group            FileAssetGroup
  size             Int
  mimeType         String
  filename         String
  status           FileAssetStatus   @default(active)
  refCount         Int               @default(0)
  lastReferencedAt DateTime?
  createdAt        DateTime          @default(now())
  references       FileReference[]
  mobileBundles    MobileBundle[]
  learningPackages LearningPackage[]
  deltaPackages    DeltaPackage[]

  @@index([group, status, createdAt(sort: Desc)])
  @@index([status, refCount, createdAt])
  @@map("file_asset")
}

model FileReference {
  id        String    @id @default(cuid())
  asset     FileAsset @relation(fields: [assetId], references: [id])
  assetId   String
  bizType   String
  bizId     String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime  @default(now())

  @@unique([assetId, bizType, bizId, userId])
  @@index([bizType, bizId, userId])
  @@map("file_reference")
}

// ---- 消息通知域 ----

enum TtsProvider {
  minimax
  cartesia
}

// ---- 消息通知域 ----

enum NotificationType {
  broadcast
  targeted
}

model Notification {
  id        String               @id @default(cuid())
  title     String
  content   String               @db.Text /// Markdown 格式内容
  type      NotificationType
  sentBy    User                 @relation(fields: [sentById], references: [id])
  sentById  String
  isSpecial Boolean              @default(false)
  imageUrl  String? /// 特殊通知的活动图片 URL（首页横幅用）
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  reads     NotificationRead[]
  targets   NotificationTarget[]

  @@index([type, createdAt(sort: Desc)])
  @@map("notification")
}

model NotificationRead {
  id             String       @id @default(cuid())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId, readAt(sort: Desc)])
  @@map("notification_read")
}

model NotificationTarget {
  id             String       @id @default(cuid())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_target")
}

// ──── 优惠券/促销域 ────

enum CouponType {
  percentage
  fixed
  free_trial
}

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Float /// 折扣值（百分比如20=20%，固定金额单位分，试用天数）
  minAmount  Float? /// 最低消费金额（分）
  maxUses    Int?
  usedCount  Int        @default(0)
  validFrom  DateTime   @default(now())
  validUntil DateTime?
  isActive   Boolean    @default(true)
  orders     Order[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("coupon")
}

// ──── 邀请域 ────

model ReferralCode {
  id           String     @id @default(cuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code         String     @unique
  totalInvited Int        @default(0)
  totalReward  Int        @default(0)
  createdAt    DateTime   @default(now())
  referrals    Referral[]

  @@map("referral_code")
}

model Referral {
  id             String       @id @default(cuid())
  referrerId     String
  referrer       ReferralCode @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String       @unique
  referredUser   User         @relation(fields: [referredUserId], references: [id], onDelete: Cascade)
  rewardedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([referrerId])
  @@map("referral")
}

// ──── 反馈域 ────

enum FeedbackStatus {
  pending
  resolved
  closed
}

model Feedback {
  id         String         @id @default(cuid())
  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  type       String         @default("other")
  content    String         @db.Text
  contact    String?
  status     FeedbackStatus @default(pending)
  isCritical Boolean        @default(false)
  adminNote  String?        @db.Text
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([isCritical, status])
  @@map("feedback")
}

// ════════════════════════════════════════════════════════════
// English Output Training — 新增模型
// ════════════════════════════════════════════════════════════

// ──── Chunk 掌握状态枚举 ────
enum ChunkMasteryStatus {
  not_learned
  activated
  can_read
  can_output
  mastered
}

// ──── 表达库条目类型 ────
enum ExpressionType {
  word
  chunk
  error_sentence
  upgraded
  scene_phrase
  custom
}

// ──── 成就 V2 枚举 ────
enum AchievementCategory {
  milestone
  streak
  challenge
  mastery
  hidden
  first_time
}

enum AchievementRarity {
  common
  rare
  epic
  legendary
}

enum UserAchievementStatus {
  locked
  unlocked
  seen
}

// ──── 场景系统 ────

model SceneCategory {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  sortOrder Int      @default(0)
  scenes    Scene[]
  createdAt DateTime @default(now())

  @@map("scene_category")
}

model Scene {
  id                  String              @id @default(cuid())
  category            SceneCategory       @relation(fields: [categoryId], references: [id])
  categoryId          String
  packageType         LearningPackageType @default(daily)
  title               String
  location            String
  description         String?
  requiredOutputLevel String              @default("L1")
  requiredUserLevel   Int                 @default(1)
  isFree              Boolean             @default(false) // 免费用户可访问
  prerequisiteScenes  ScenePrerequisite[] @relation("Scene")
  prerequisiteFor     ScenePrerequisite[] @relation("Prerequisite")
  trainingTopics      TrainingTopic[]
  storyEpisodes       StoryEpisode[]
  userProgresses      UserSceneProgress[]
  gameLocations       GameLocation[]
  learningPackages    LearningPackage[]
  createdAt           DateTime            @default(now())

  @@map("scene")
}

enum LearningPackageStatus {
  draft
  building
  published
  failed
}

enum LearningPackageType {
  daily
  exam
  story
  course
  foundation
}

enum TrainingTopicType {
  daily
  ielts
}

model LearningPackage {
  id               String                @id @default(cuid())
  scene            Scene                 @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId          String
  version          Int
  title            String
  type             LearningPackageType   @default(daily)
  status           LearningPackageStatus @default(draft)
  fileAsset        FileAsset?            @relation(fields: [fileAssetId], references: [id])
  fileAssetId      String?
  zipChecksum      String?
  zipSize          Int?
  manifestSnapshot Json?
  buildLog         String?
  publishedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deltaPackages    DeltaPackage[]

  @@unique([sceneId, version])
  @@index([sceneId, status, version])
  @@map("learning_package")
}

model DeltaPackage {
  id            String          @id @default(cuid())
  pack          LearningPackage @relation(fields: [packId], references: [id], onDelete: Cascade)
  packId        String
  fromVersion   Int
  toVersion     Int
  fileAsset     FileAsset       @relation(fields: [fileAssetId], references: [id])
  fileAssetId   String
  deltaChecksum String
  deltaSize     Int
  addedCount    Int             @default(0)
  modifiedCount Int             @default(0)
  removedCount  Int             @default(0)
  createdAt     DateTime        @default(now())

  @@unique([packId, fromVersion, toVersion])
  @@index([packId])
  @@map("delta_package")
}

model ScenePrerequisite {
  id             String @id @default(cuid())
  scene          Scene  @relation("Scene", fields: [sceneId], references: [id])
  sceneId        String
  prerequisite   Scene  @relation("Prerequisite", fields: [prerequisiteId], references: [id])
  prerequisiteId String

  @@unique([sceneId, prerequisiteId])
  @@map("scene_prerequisite")
}

// ──── Chunk 表达块 ────

model Chunk {
  id                 String               @id @default(cuid())
  text               String
  meaning            String
  description        String?              @db.Text
  category           String
  difficulty         String               @default("L2")
  examples           ChunkExample[]
  userProgresses     UserChunkProgress[]
  storyEpisodeChunks StoryEpisodeChunk[]
  topicChunks        TrainingTopicChunk[]
  createdAt          DateTime             @default(now())

  @@unique([text])
  @@index([difficulty])
  @@map("chunk")
}

model Vocabulary {
  id                       String                   @id @default(cuid())
  word                     String
  meaning                  String // 中文释义
  partOfSpeech             String? // 词性：noun/verb/adj/phrase
  phoneticUs               String? // 美式音标
  phoneticUk               String? // 英式音标
  audioUsUrl               String? // 美式发音音频
  audioUkUrl               String? // 英式发音音频
  definitionEn             String?                  @db.Text // 英文释义
  synonyms                 String[]                 @default([]) // 同义词
  examples                 Json? // 例句 [{ en, zh, note? }]
  description              String?                  @db.Text // 用法讲解/搭配说明
  difficulty               String                   @default("L1") // L1~L5
  sortOrder                Int                      @default(0)
  outputPriority           String                   @default("low") @map("output_priority") // low | medium | high
  collocations             Json?                    @map("collocations")
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  storyEpisodeVocabularies StoryEpisodeVocabulary[]
  topicVocabs              TrainingTopicVocab[]

  @@unique([word])
  @@map("vocabulary")
}

model TrainingTopicVocab {
  id        String        @id @default(cuid())
  topic     TrainingTopic @relation(fields: [topicId], references: [id])
  topicId   String
  vocab     Vocabulary    @relation(fields: [vocabId], references: [id])
  vocabId   String
  sortOrder Int           @default(0)

  @@unique([topicId, vocabId])
  @@map("training_topic_vocab")
}

model ChunkExample {
  id        String   @id @default(cuid())
  chunk     Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  chunkId   String
  en        String   @db.Text
  zh        String   @db.Text
  note      String?  @db.Text
  level     String   @default("basic")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([chunkId, sortOrder])
  @@map("chunk_example")
}

// ──── 用户 Chunk 掌握度 ────

model UserChunkProgress {
  id              String             @id @default(cuid())
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  chunk           Chunk              @relation(fields: [chunkId], references: [id])
  chunkId         String
  status          ChunkMasteryStatus @default(not_learned)
  seenCount       Int                @default(0)
  spokenCount     Int                @default(0)
  correctUseCount Int                @default(0)
  usedSceneIds    String[]           @default([])
  lastPracticedAt DateTime?
  updatedAt       DateTime           @updatedAt

  @@unique([userId, chunkId])
  @@map("user_chunk_progress")
}

// ──── 训练话题 ────

model TrainingTopic {
  id                         String                         @id @default(cuid())
  scene                      Scene                          @relation(fields: [sceneId], references: [id])
  sceneId                    String
  type                       TrainingTopicType              @default(daily)
  title                      String
  description                String?                        @db.Text
  knowledgePoints            String?                        @db.Text
  teachingMarkdown           String?                        @db.Text
  promptEn                   String                         @db.Text
  promptZh                   String                         @db.Text
  suggestedDurationSec       Int                            @default(60)
  difficulty                 String                         @default("L2")
  metadata                   Json?
  activeChunks               TrainingTopicChunk[]
  topicPatterns              TrainingTopicSentencePattern[]
  topicVocabs                TrainingTopicVocab[]
  practiceSessions           PracticeSession[]
  sentencePatternsDeprecated Json?                          @map("sentence_patterns")
  inkScriptId                String?                        @unique
  inkScript                  InkScript?                     @relation("TopicInkScript", fields: [inkScriptId], references: [id])
  sortOrder                  Int                            @default(0)
  createdAt                  DateTime                       @default(now())

  @@index([sceneId, difficulty])
  @@map("training_topic")
}

model SentencePattern {
  id          String   @id @default(cuid())
  pattern     String
  meaning     String?
  category    String?
  description String?  @db.Text
  slots       Json?
  examples    Json?
  difficulty  String   @default("L1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topicPatterns        TrainingTopicSentencePattern[]
  storyEpisodePatterns StoryEpisodeSentencePattern[]

  @@unique([pattern])
  @@map("sentence_pattern")
}

model TrainingTopicSentencePattern {
  id        String          @id @default(cuid())
  topic     TrainingTopic   @relation(fields: [topicId], references: [id])
  topicId   String
  pattern   SentencePattern @relation(fields: [patternId], references: [id])
  patternId String
  sortOrder Int             @default(0)

  @@unique([topicId, patternId])
  @@index([topicId, sortOrder])
  @@map("training_topic_sentence_pattern")
}

model PracticeSession {
  id                       String         @id @default(cuid())
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   String
  topic                    TrainingTopic  @relation(fields: [topicId], references: [id])
  topicId                  String
  sceneId                  String
  inkScriptId              String?
  status                   String         @default("active")
  topicSnapshot            Json
  sceneSnapshot            Json
  objectivesSnapshot       Json
  chunksSnapshot           Json
  vocabSnapshot            Json
  sentencePatternsSnapshot Json?
  turnCount                Int            @default(0)
  analysisResult           Json?
  analysisRaw              String?        @db.Text
  analysisError            String?        @db.Text
  startedAt                DateTime       @default(now())
  completedAt              DateTime?
