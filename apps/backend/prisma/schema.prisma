// ──── 探索模式（视觉小说架构）───

model GameCharacter {
  id                 String              @id @default(cuid())
  name               String
  displayName        String
  role               String
  personality        String?
  avatarUrl          String?
  spriteBaseUrl      String?
  expressions        Json?
  defaultPosition    String?
  ttsVoice           String? // TTS 音色 ID（如 MiniMax/Cartesia voice ID）
  ttsModel           String? // TTS 模型（如 speech-2.8-hd）
  ttsParams          Json? // TTS 参数（如 { speed, pitch, vol }）
  roomNpcs           GameRoomNpc[]
  explorationRecords ExplorationRecord[]
  createdAt          DateTime            @default(now())

  @@map("game_character")
}

model GameMap {
  id                  String         @id @default(cuid())
  name                String
  displayName         String
  backgroundUrl       String?
  thumbnailUrl        String?
  icon                String?
  width               Int            @default(1920)
  height              Int            @default(1080)
  editorData          Json?
  locations           GameLocation[]
  requiredOutputLevel String         @default("L1")
  requiredChapterId   String?
  disabled            Boolean        @default(false)
  hidden              Boolean        @default(false)
  isPreview           Boolean        @default(false)
  sortOrder           Int            @default(0)
  createdAt           DateTime       @default(now())

  @@map("game_map")
}

// ──── NQTR Navigation: Map → Location → Room（Pixi-VN 三级层级）────

model GameLocation {
  id                  String         @id @default(cuid())
  map                 GameMap        @relation(fields: [mapId], references: [id])
  mapId               String
  name                String
  displayName         String
  description         String?
  posX                Float          @default(0)
  posY                Float          @default(0)
  icon                String?
  iconWidth           Int            @default(26)
  iconHeight          Int            @default(26)
  backgroundUrl       String?
  bgmUrl              String?
  ambientUrl          String?
  locationType        String         @default("building")
  sceneId             String?
  scene               Scene?         @relation(fields: [sceneId], references: [id])
  rooms               GameRoom[]
  explorationRecords  ExplorationRecord[]
  requiredOutputLevel String         @default("L1")
  requiredSceneIds    String[]       @default([])
  requiredFlags       Json?
  disabled            Boolean        @default(false)
  hidden              Boolean        @default(false)
  isPreview           Boolean        @default(false)
  sortOrder           Int            @default(0)
  createdAt           DateTime       @default(now())

  @@map("game_location")
}

model GameRoom {
  id                  String              @id @default(cuid())
  location            GameLocation        @relation(fields: [locationId], references: [id])
  locationId          String
  name                String
  displayName         String
  description         String?
  backgroundUrl       String?
  bgmUrl              String?
  ambientUrl          String?
  icon                String?
  roomType            String              @default("vn_scene")
  isEntrance          Boolean             @default(false)
  disabled            Boolean             @default(false)
  hidden              Boolean             @default(false)
  npcs                GameRoomNpc[]
  explorationRecords  ExplorationRecord[]
  inkScriptId         String?
  requiredOutputLevel String              @default("L1")
  requiredFlags       Json?
  isPreview           Boolean             @default(false)
  sortOrder           Int                 @default(0)
  createdAt           DateTime            @default(now())

  @@map("game_room")
}

// ──── NQTR Routine: NPC 绑定到 Room ────

model GameRoomNpc {
  id              String        @id @default(cuid())
  room            GameRoom      @relation(fields: [roomId], references: [id])
  roomId          String
  character       GameCharacter @relation(fields: [characterId], references: [id])
  characterId     String
  schedule        Json?
  defaultGreeting String?
  inkTalkScriptId String?
  sortOrder       Int           @default(0)

  @@unique([roomId, characterId])
  @@map("game_room_npc")
}

// ──── Ink 叙事脚本 & 游戏存档 ────

