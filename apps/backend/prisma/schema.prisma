// ── AI 额度追踪 ──

model AiUsageDaily {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date

  dialogue Int @default(0) // 对话判定次数
  summary  Int @default(0) // 汇总/分析次数
  tokens   Int @default(0) // 总 token 消耗量

  @@unique([userId, date])
  @@index([userId])
  @@map("ai_usage_daily")
}

// ── OTA 热更新：MobileBundle 安装包管理（zip 存在 COS，关联 FileAsset）──

model MobileBundle {
  id               String    @id @default(cuid())
  version          String // 语义化版本号，如 "1.2.3"
  platform         String // ios | android
  channel          String    @default("production") // production | staging
  assetId          String // 关联 FileAsset（COS 上的 zip 文件）
  asset            FileAsset @relation(fields: [assetId], references: [id])
  checksum         String // SHA256 校验值
  minNativeVersion String? // 最低原生版本要求
  rolloutPercent   Int       @default(100) // 灰度比例 0-100
  enabled          Boolean   @default(true) // 是否启用（可快速下架）
  isMandatory      Boolean   @default(false) // 是否强制更新（忽略灰度，下载后立即提示重启）
  releaseNotes     String?   @db.Text // 更新日志
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([version, platform, channel])
  @@index([platform, channel, enabled])
  @@index([assetId])
  @@map("mobile_bundle")
}

// ──── 词典条目（FreeDictionaryAPI 清洗后数据）────

model DictionaryEntry {
  word            String   @id /// 小写单词，作为主键
  language        String   @default("en")
  sourceUrl       String? /// Wiktionary 原始页面 URL（CC BY-SA 4.0 署名用）
  pronunciations  Json     @default("[]") /// CleanedPronunciation[]
  senseClusters   Json     @default("[]") /// SenseCluster[] — 聚类后的语义分组
  senses          Json     @default("[]") /// CleanedSense[] — 所有清洗后的义项（引用 clusterId）
  entrySynonyms   Json     @default("[]") /// string[] — 词条级别同义词（来自 Wiktionary）
  wordForms       Json     @default("[]") /// { word: string, tags: string[] }[] — 复数/过去式等词形变化
  rawEntry        Json? /// FreeDictionaryAPI 原始响应（调试/重新处理用）
  pipelineVersion String   @default("1.0")
  aiReviewed      Boolean  @default(false)
  aiReviewMeta    Json? /// { reviewedAt, issuesFound, fixesApplied, modelUsed }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([language])
  @@map("dictionary_entry")
}
