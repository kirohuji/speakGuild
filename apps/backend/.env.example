# ====== Backend (NestJS) ======
# NestJS ConfigModule 自动加载此文件

# ── 应用 ──
PORT=3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# ── 数据库 ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/manyu

# ── Better Auth ──
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=your-32-char-secret-here-change-me

# ── 腾讯云（COS/STT/SMS 共用密钥）──
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key
TENCENT_REGION=ap-guangzhou

# ── 腾讯云短信（SMS）──
TENCENT_SMS_APP_ID=1400xxxxxx
TENCENT_SMS_SIGN_NAME=你的签名
TENCENT_SMS_TEMPLATE_ID=1234567

# ── AI ──
DEEPSEEK_API_KEY=your-deepseek-key

# ── Redis / BullMQ 后台任务队列 ──
REDIS_URL=redis://:your-redis-password@127.0.0.1:6379

# ── TTS ──
MINIMAX_API_KEY=your-minimax-key
MINIMAX_GROUP_ID=your-minimax-group

REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer rc_webhook_lourd
REVENUECAT_PROJECT_ID=sk_rdjQbgbeTDuoCDQzJbkrymzyrdelv

# ── 稳定性监控 / 运营告警（不填则关闭）──
SENTRY_DSN=
OPS_SERVICE_NAME=manyu-backend
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_WEBHOOK_AUTHORIZATION=
OPS_ALERT_MIN_INTERVAL_SECONDS=300
OPS_CAPACITY_CHECK_CRON=0 15 9 * * *
OPS_DB_MAX_BYTES=0
OPS_FILE_ASSET_MAX_BYTES=0
