{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../frontend/src/*"]
    }
  },
  "include": ["src", "../frontend/src/features/company/pages/**/*", "../frontend/src/components/ui/badge.tsx", "../frontend/src/components/ui/dialog.tsx", "../frontend/src/components/ui/separator.tsx", "../frontend/src/lib/cn.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
