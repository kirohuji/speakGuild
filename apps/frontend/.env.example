# Type a script or drag a script file from your workspace to insert its path.
# Xcode 16 SPM 会把静态库 WechatOpenSDK 误嵌入 Frameworks 目录
# App Store 错误 90208: 静态 framework 不支持嵌入
rm -rf "${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/WechatOpenSDK.framework"
