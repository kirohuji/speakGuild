{
  "name": "@manyu/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "cap:copy": "pnpm build && pnpm exec cap copy",
    "cap:sync": "pnpm build && pnpm exec cap sync",
    "cap:sync:ios": "pnpm build && pnpm exec cap sync ios",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:zip": "pnpm build && cd dist && zip -r bundle.zip .",
    "shasum": "certutil -hashfile dist.zip SHA256",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:mobile": "playwright test --project=iPhone15 --project=Pixel7"
  },
