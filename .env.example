# ====== 数据库 (Docker Compose) ======
POSTGRES_USER=manyu
POSTGRES_PASSWORD=manyu
POSTGRES_DB=manyu

# ====== Backend ======
# 本地开发数据库 (直连本地 PostgreSQL)
DATABASE_URL="postgresql://manyu:manyu@localhost:5432/manyu"
# Docker 部署时使用: postgresql://manyu:manyu@db:5432/manyu
PORT=3001
FRONTEND_URL=http://localhost:5173,capacitor://localhost,ionic://localhost
BACKEND_URL=http://localhost:3001

# ====== Better Auth ======
