# ====== 文件清理任务 ======
FILE_CLEANUP_CRON=0 30 3 * * *
FILE_CLEANUP_DAYS=7
FILE_CLEANUP_DRY_RUN=false

# ====== Docker 构建 ======
NPM_REGISTRY=https://registry.npmmirror.com
SSL_DEPLOY=./ssl

# ====== Frontend (Vite) ======
VITE_API_BASE_URL=/api/v1/manyu
VITE_AUTH_BASE_URL=http://localhost:3001
