# ====== COS 对象存储 ======
COS_BUCKET=
COS_REGION=ap-shanghai
COS_SECRET_ID=
COS_SECRET_KEY=
COS_PRIVATE_URL_EXPIRES_SECONDS=3600

# ====== 腾讯云通用（COS/STT/SMS 可共用同一对密钥）======
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou

# ====== 腾讯云短信（SMS）- 手机验证码 ======
